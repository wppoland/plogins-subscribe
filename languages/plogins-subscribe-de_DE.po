#. Plugin Name of the plugin
#: subscribe.php
msgid "Subscribe - Newsletter Opt-In for WooCommerce"
msgstr "Abonnieren – Newsletter-Opt-In für WooCommerce"

#. Plugin URI of the plugin
#: subscribe.php
msgid "https://plogins.com/subscribe/"
msgstr "https://plogins.com/de/subscribe/"

#. Description of the plugin
#: subscribe.php
msgid ""
"Add a newsletter opt-in at checkout and collect subscribers with consent."
msgstr ""
"Füge an der Kasse ein Newsletter-Opt-in hinzu und sammeln Sie Abonnenten mit"
" Einwilligung."

#. Author of the plugin
#: subscribe.php
msgid "WPPoland.com"
msgstr "WPPoland.com"

#. Author URI of the plugin
#: subscribe.php
msgid "https://wppoland.com"
msgstr "https://wppoland.com"

#: src/Admin/Export.php:57
msgid ""
"Export every subscriber (email, consent, source and date) to a CSV file."
msgstr ""
"Exportiere jeden Abonnenten (E-Mail, Einwilligung, Quelle und Datum) in eine"
" CSV-Datei."

#: src/Admin/Export.php:59
msgid "Export to CSV"
msgstr "Als CSV exportieren"

