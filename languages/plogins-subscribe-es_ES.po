#. Plugin Name of the plugin
#: subscribe.php
msgid "Subscribe - Newsletter Opt-In for WooCommerce"
msgstr "Suscríbete - Suscripción al boletín informativo para WooCommerce"

#. Plugin URI of the plugin
#: subscribe.php
msgid "https://plogins.com/subscribe/"
msgstr "https://plogins.com/es/subscribe/"

#. Description of the plugin
#: subscribe.php
msgid ""
"Add a newsletter opt-in at checkout and collect subscribers with consent."
msgstr ""
"Añade una suscripción al boletín al finalizar la compra y recopile "
"suscriptores con su consentimiento."

#. Author of the plugin
#: subscribe.php
msgid "WPPoland.com"
msgstr "WPPoland.com"

#. Author URI of the plugin
#: subscribe.php
msgid "https://wppoland.com"
msgstr "https://wppoland.com"

